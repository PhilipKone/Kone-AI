{
    "name":  "kone-ai",
    "private":  true,
    "version":  "0.0.0",
    "type":  "module",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "vite build",
                    "postbuild":  "react-snap",
                    "lint":  "eslint .",
                    "preview":  "vite preview",
                    "predeploy":  "npm run build",
                    "deploy":  "gh-pages -d dist --dotfiles -r https://github.com/PhilipKone/Kone-AI.git",
                    "postinstall":  "node patch-react-snap.cjs"
                },
    "dependencies":  {
                         "axios":  "^1.16.1",
                         "framer-motion":  "^12.38.0",
                         "lucide-react":  "^1.16.0",
                         "react":  "^19.2.6",
                         "react-dom":  "^19.2.6"
                     },
    "devDependencies":  {
                            "@eslint/js":  "^10.0.1",
                            "@types/react":  "^19.2.14",
                            "@types/react-dom":  "^19.2.3",
                            "@vitejs/plugin-react":  "^6.0.1",
                            "autoprefixer":  "^10.5.0",
                            "eslint":  "^10.3.0",
                            "eslint-plugin-react-hooks":  "^7.1.1",
                            "eslint-plugin-react-refresh":  "^0.5.2",
                            "globals":  "^17.6.0",
                            "postcss":  "^8.5.14",
                            "react-snap":  "^1.23.0",
                            "tailwindcss":  "^3.4.19",
                            "gh-pages":  "^6.0.0",
                            "vite":  "^8.0.12"
                        },
    "reactSnap":  {
                      "source":  "dist",
                      "delay": 1000,
                      "port": 45680,
                      "puppeteerArgs":  [
                                            "--no-sandbox",
                                            "--disable-setuid-sandbox"
                                        ]
                  },
    "overrides":  {
                      "react-snap":  {
                                         "puppeteer":  "^22.0.0"
                                     }
                  }
}
